APP_NAME=API Monitoramento
APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/monitoring.db
MONITORING_INTERVAL_SECONDS=60
HISTORY_LIMIT_PER_SERVER=100
CONNECT_TIMEOUT_SECONDS=10
COMMAND_TIMEOUT_SECONDS=20
DOCKER_COMMAND_TIMEOUT_SECONDS=45
DOCKER_LOGS_COMMAND_TIMEOUT_SECONDS=120
DOCKER_LOGS_FALLBACK_TAIL_LINES=50
MAX_CONCURRENT_CHECKS=5
API_KEY=
MONITORING_ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:4173
CORS_ALLOWED_ORIGIN_REGEX=https://.*\.lovable\.app
CORS_ALLOW_CREDENTIALS=false
